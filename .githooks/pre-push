#!/usr/bin/env bash
# Runs the full test suite before every push.
# Also blocks direct pushes to main — use a PR instead.
# To skip in an emergency: git push --no-verify

set -e

CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
PROTECTED="main"

if [ "$CURRENT_BRANCH" = "$PROTECTED" ]; then
  echo "✗ Direct pushes to '$PROTECTED' are not allowed."
  echo "  Create a feature branch and open a PR:"
  echo "    git checkout -b feat/your-feature"
  echo "    git push -u origin feat/your-feature"
  echo "    gh pr create"
  echo ""
  echo "  To bypass in an emergency: git push --no-verify"
  exit 1
fi

ROOT="$(git rev-parse --show-toplevel)"

echo "▶ Running frontend tests…"
cd "$ROOT/frontend" && npm test -- --no-coverage --ci

echo "▶ Running backend tests…"
cd "$ROOT/backend"
# Activate venv if present, otherwise fall back to system pytest
if [ -f venv/bin/activate ]; then
  source venv/bin/activate
fi
pytest --tb=short -q

echo "✓ All tests passed."
