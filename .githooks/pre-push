#!/usr/bin/env bash
# Runs the full test suite before every push.
# Also blocks direct pushes to main — use a PR instead.
# To skip in an emergency: git push --no-verify

set -e

CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
PROTECTED="main"

if [ "$CURRENT_BRANCH" = "$PROTECTED" ]; then
  echo "✗ Direct pushes to '$PROTECTED' are not allowed."
  echo "  Create a feature branch and open a PR:"
  echo "    git checkout -b feat/your-feature"
  echo "    git push -u origin feat/your-feature"
  echo "    gh pr create"
  echo ""
  echo "  To bypass in an emergency: git push --no-verify"
  exit 1
fi

ROOT="$(git rev-parse --show-toplevel)"

echo "▶ Running frontend unit tests (Jest)…"
cd "$ROOT/frontend" && npm test -- --no-coverage --ci

# Run E2E only if Playwright browsers are installed. This is intentional:
# we don't want to force every contributor to install ~100 MB of browsers
# on their first push. If E2E files changed, skipping is risky, so warn.
if [ -d "$HOME/Library/Caches/ms-playwright" ] || [ -d "$HOME/.cache/ms-playwright" ]; then
  echo "▶ Running frontend E2E tests (Playwright)…"
  # Strip ambient env vars that should come from playwright.config.ts so a
  # missing var in CI can't be hidden by a local .env.local on your machine.
  env -u AUTH_SECRET -u AUTH_GOOGLE_ID -u AUTH_GOOGLE_SECRET -u NEXT_PUBLIC_API_URL \
    npm run test:e2e
else
  echo "⚠ Skipping E2E — Playwright browsers not installed. Run 'cd frontend && npx playwright install chromium'"
  # Hard-fail if the push touches E2E-related files
  if git diff --cached --name-only HEAD origin/HEAD 2>/dev/null | grep -qE "^frontend/(e2e/|playwright\.config|src/middleware\.ts|src/auth\.ts)"; then
    echo "✗ E2E-related files changed but Playwright is not installed — install it first."
    exit 1
  fi
fi

echo "▶ Running backend tests (pytest)…"
cd "$ROOT/backend"
if [ -f venv/bin/activate ]; then
  source venv/bin/activate
fi
pytest --tb=short -q

echo "✓ All tests passed."
