require "base64"
require "securerandom"
require "tmpdir"

default_platform(:ios)

# Paths relative to frontend/ (where Fastlane is invoked from)
APP_PROJECT = "ios/App/App.xcodeproj"
APP_SCHEME  = "App"

platform :ios do
  # ────────────────────────────────────────────────────────────────────────────
  # beta  — build a Release IPA and upload it to TestFlight
  # ────────────────────────────────────────────────────────────────────────────
  desc "Build and upload to TestFlight"
  lane :beta do
    kc_pass = ENV.fetch("KEYCHAIN_PASSWORD", SecureRandom.hex(16))

    # 1. Isolated keychain so the runner's system keychain is untouched
    if ENV["CI"]
      create_keychain(
        name:             "build",
        password:         kc_pass,
        default_keychain: true,
        unlock:           true,
        timeout:          3600,
        lock_when_sleeps: false,
      )
    end

    # 2. Import App Store distribution certificate from base64 secret
    cert_path = File.join(Dir.tmpdir, "dist.p12")
    File.binwrite(cert_path, Base64.decode64(ENV.fetch("IOS_DIST_CERT_BASE64")))
    import_certificate(
      certificate_path:     cert_path,
      certificate_password: ENV.fetch("IOS_DIST_CERT_PASSWORD", ""),
      keychain_name:        ENV["CI"] ? "build" : nil,
      keychain_password:    ENV["CI"] ? kc_pass : nil,
    )

    # 3. Install App Store provisioning profile from base64 secret
    profile_path = File.join(Dir.tmpdir, "dist.mobileprovision")
    File.binwrite(profile_path, Base64.decode64(ENV.fetch("IOS_PROVISIONING_PROFILE_BASE64")))
    install_provisioning_profile(path: profile_path)

    # 4. Auto-increment build number using the CI run counter
    increment_build_number(
      xcodeproj:    APP_PROJECT,
      build_number: ENV.fetch("GITHUB_RUN_NUMBER", Time.now.to_i.to_s),
    )

    # 5. Build IPA
    build_app(
      project:       APP_PROJECT,
      scheme:        APP_SCHEME,
      configuration: "Release",
      export_method: "app-store",
      clean:         true,
    )

    # 6. Upload to TestFlight (App Store Connect API key — no 2FA hassle)
    upload_to_testflight(
      api_key: {
        key_id:                ENV.fetch("ASC_KEY_ID"),
        issuer_id:             ENV.fetch("ASC_ISSUER_ID"),
        key_content:           ENV.fetch("ASC_KEY_CONTENT"),  # base64-encoded .p8
        is_key_content_base64: true,
      },
      skip_waiting_for_build_processing: true,
    )

    UI.success "Build ##{ENV.fetch('GITHUB_RUN_NUMBER', '?')} uploaded to TestFlight ✓"
  end
end
